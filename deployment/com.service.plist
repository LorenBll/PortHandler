<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- launchd plist for the service. Update paths before installation. -->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.servicehandler</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/path/to/ServiceHandler/.venv/bin/python</string>
        <string>/path/to/ServiceHandler/src/main.py</string>
    </array>
    
    <key>WorkingDirectory</key>
    <string>/path/to/ServiceHandler</string>
    
    <key>RunAtLoad</key>
    <true/>
    
    <key>KeepAlive</key>
    <true/>
    
    <key>StandardOutPath</key>
    <string>/tmp/servicehandler.log</string>
    
    <key>StandardErrorPath</key>
    <string>/tmp/servicehandler.error.log</string>
</dict>
</plist>